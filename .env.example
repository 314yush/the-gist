# Single .env file at repo root — used by all apps (API, desktop, extension build).
# Copy to .env and fill in your values.

# ============ BACKEND (apps/api) ============
# API Keys (server-side only, never expose to client)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional: LLM model for explanations and wiki generation (default: openai/gpt-4o)
# OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional: image generation model on OpenRouter (raster visuals)
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview
XAI_API_KEY=xai-your-key-here

# Auth secret for signing tokens
AUTH_SECRET=your-secret-key-here-use-openssl-rand-base64-32

# Optional: rate limiting (requests per minute per user)
RATE_LIMIT_RPM=60

# Public site URL (CORS default + OpenRouter HTTP-Referer). Defaults in code if unset.
# PUBLIC_SITE_URL=https://whatsthegist.xyz

# ============ DESKTOP (apps/desktop) ============
# Default backend URL (can be overridden in Preferences)
VITE_DEFAULT_API_URL=http://localhost:3000

# Dev only - Vite dev server URL
VITE_DEV_SERVER_URL=http://localhost:5173

# Browser-only dev (Vite at localhost:5173 without Electron): must match AUTH_SECRET for API auth
# VITE_LUMINA_DEV_TOKEN=paste-same-value-as-AUTH_SECRET-above

# Optional explicit desktop overrides (Electron main also reads repo .env via dotenv)
# LUMINA_API_URL=http://localhost:3000
# LUMINA_API_TOKEN=
