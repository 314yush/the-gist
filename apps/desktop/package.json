{
  "name": "@thegist/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "The Gist - One-click explanations personalized to your knowledge",
  "author": "The Gist",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "package": "electron-builder --mac",
    "package:dir": "electron-builder --mac --dir"
  },
  "dependencies": {
    "@thegist/shared": "workspace:*",
    "dotenv": "^17.4.1",
    "electron-store": "^8.2.0",
    "mermaid": "11"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
